# Configurazione AI Agent per Excel — modello autoritario
# Provider: 'opencode' | 'openrouter' | 'openai'
#
# Copia questo file in .env e modifica le chiavi.
# Il .env reale è in .gitignore — NON committare chiavi API.

# ============================================
# OPZIONE 1: OpenCode Go (server locale)
# ============================================
# AI_PROVIDER=opencode
# OPENCODE_SERVER_URL=http://127.0.0.1:4096
# OPENCODE_PROVIDER=opencode-go
# OPENCODE_MODEL=kimi-k2.6

# ============================================
# OPZIONE 2: OpenRouter (online, API key) — RACCOMANDATA
# ============================================
# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=moonshotai/kimi-k2.6
# OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
# LLM_TIMEOUT_MS=90000
# LLM_FALLBACK_TIMEOUT_MS=45000
# PLANNER_TIMEOUT_MS=150000
# PLANNER_FALLBACK_TIMEOUT_MS=60000

# ============================================
# OPZIONE 3: OpenAI-compatible generico
# ============================================
# AI_PROVIDER=openai
# AI_API_URL=https://api.openai.com/v1/chat/completions
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# ============================================
# OPZIONE 4: Xiaomi MiMo (token subscription, API diretta)
# ============================================
# AI_PROVIDER=xiaomi
# XIAOMI_API_URL=https://token-plan-ams.xiaomimimo.com/v1/chat/completions
# XIAOMI_API_KEY=tp-...
# XIAOMI_MODEL=mimo-v2.5-pro
# XIAOMI_FALLBACK_MODEL=deepseek/deepseek-v4-flash

# ============================================
# OPZIONE 5: DeepSeek API diretta (reasoning + context caching automatico)
# ============================================
# AI_PROVIDER=deepseek
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_FALLBACK_MODEL=deepseek-chat
# DEEPSEEK_REASONING_EFFORT=high
# DEEPSEEK_THINKING_ENABLED=true

# ============================================
# MODELLI PER RUOLO (preludio Fase 4)
# ============================================
# MODEL_PRIMARY=moonshotai/kimi-k2.6
# MODEL_FAST=openai/gpt-4o-mini
# MODEL_VALIDATOR=openai/gpt-4o-mini

# ============================================
# LOG LEVEL: info | warn | error | debug
# ============================================
# LOG_LEVEL=info

# ============================================
# CLIENT REQUESTS SWEEP
# ============================================
# SWEEP_INTERVAL_MS=5000
# MAX_PENDING_AGE_MS=120000

# ============================================
# TURNS CLEANUP
# ============================================
# MAX_TURN_FILES=100

# ============================================
# OpenBB Financial Data Platform (installare con: pip install "openbb[all]")
# Avvia il server REST: source .venv-openbb/bin/activate && openbb-api --port 6900
# ============================================
# OPENBB_API_URL=http://127.0.0.1:6900
# OPENBB_TIMEOUT_MS=30000
# OPENBB_RETRY_COUNT=2
# OPENBB_ENABLED=true
# 
# Provider API keys (opzionali, per sbloccare più endpoint)
# FREE TIER: https://financialmodelingprep.com (FMP) — sblocca equity fundamentals avanzati
# OPENBB_FMP_API_KEY=your_fmp_key
# OPENBB_FRED_API_KEY=your_fred_key

# Porte server locale
PORT=3000
HTTPS_PORT=3443
