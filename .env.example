# Excel AI Agent — configurazione
# Copia in .env e imposta i valori reali

# Server
PORT=3000
PUBLIC_URL=http://localhost:3000

# Auth (generato automaticamente se assente)
JWT_SECRET=

# LLM — OpenRouter (unico provider)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_FALLBACK_MODEL=qwen/qwen3-coder
