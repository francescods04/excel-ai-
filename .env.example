# Excel AI Agent — configurazione

# Server
PORT=3000
PUBLIC_URL=http://localhost:3000

# CORS / Deploy (Vercel / production)
# ALLOW_ALL_CORS=true              # ⚠️ Apre CORS a tutte le origini — usa solo in dev locale
# ALLOWED_ORIGINS=https://tuodominio.vercel.app,https://excel.office.com

# Supabase (auth + database)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# LLM — DeepSeek (primario)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true

# LLM — OpenRouter (fallback opzionale)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# Runtime UX flags
# PLANNER_STREAM_TIMEOUT_MS=45000  # max attesa streaming planner prima del fallback non-streaming
# PLANNER_TIMEOUT_MS=300000        # timeout completo planner
# PLANNER_WEAK_FINANCE_FALLBACK=true  # se il piano LLM finance e debole, usa subito il playbook deterministico
# PLANNER_THINKING_ENABLED=false   # planner LLM: off di default per ridurre latenza
# TRIAGE_THINKING_ENABLED=false    # triage veloce: classificazione senza thinking
# ARCHITECT_THINKING_ENABLED=true  # blueprint architect: lascia thinking attivo solo qui
# AGENT_LOOP_FAST_MODEL=deepseek-v4-flash   # loop rapido: modello default per task locali/incrementali
# AGENT_LOOP_MODEL=deepseek-v4-flash        # loop strutturato: tienilo flash salvo casi speciali
# AGENT_THINKING_EVERY_ITER=false           # evita thinking su ogni iterazione: molto piu veloce
# AGENT_THINKING_INTERVAL=6                 # riattiva thinking ogni N iterazioni per riallineare il loop
# AGENT_FORCE_THINKING_AFTER_ERROR=true     # dopo parse error / tool error forza 1 iterazione "thinking"
# AGENT_STAGNATION_MAX_REPEAT=4    # abort dopo N chiamate identiche dei tool di lettura/JS
# AGENT_STAGNATION_ALT_CYCLES=3    # abort dopo N cicli alternati read/write ripetuti
# DISABLE_QUOTA=true            # skippa il limite giornaliero di turn (beta/dev)
# AUTO_APPROVE_ALL=true         # auto-approva piani + mutazioni (no popup conferma)
# PARALLEL_ORCHESTRATOR_MAX=4   # slice in parallel per architect+parallel mode
# DISABLE_TRIAGE=true           # disabilita la classificazione AI upfront (debug)
